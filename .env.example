# Acty environment variables.
# Copy to `.env.local` and fill in. NEXT_PUBLIC_* values are baked into the
# static build and are safe to expose in the browser (protected by RLS).

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-side secrets: NEVER put these in NEXT_PUBLIC_* or commit them. ---
# They live only in Supabase Edge Function secrets (set via `supabase secrets set`).
# SUPABASE_SERVICE_ROLE_KEY=
# RESEND_API_KEY=
